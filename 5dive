chmod 600 "$ENV_FILE"
TMP=$(mktemp --tmpdir="$HOME/.hermes" .env.XXXXXX)
chmod 600 "$TMP"
cp "$ENV_FILE" "$TMP"
key="${PAIR%%=*}"
grep -v "^${key}=" "$TMP" > "$TMP.next" || true
mv "$TMP.next" "$TMP"
printf '%s\n' "$PAIR" >> "$TMP"
mv "$TMP" "$ENV_FILE"
HERMES_BYO_ENV
  then
    fail "$E_GENERIC" "hermes BYO env write failed for agent '$name' ($var)"
